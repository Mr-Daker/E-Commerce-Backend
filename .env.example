# Local development only. Replace these values outside an isolated workstation.
SHOP_API_USERNAME=shop-user
SHOP_API_PASSWORD=change-me

MYSQL_ROOT_PASSWORD=root
RABBITMQ_USERNAME=shopping
RABBITMQ_PASSWORD=shopping

GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin

# Gateway defaults. These are documented here for deployments that override them.
GATEWAY_RATE_PER_SECOND=20
GATEWAY_BURST_CAPACITY=40
GATEWAY_MAX_REQUEST_SIZE=1MB
